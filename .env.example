# =============================================================================
# AI Supply Chain Optimizer — environment template
# Copy this file to `.env` and fill in real values for local development.
# Never commit `.env`; only `.env.example` is tracked.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLAlchemy connection URL. SQLite is the default for Phase 2 (fast iteration).
# Switch to the Postgres URL once you bring up docker-compose (Phase 2.5).
#   Postgres URL (matches the docker-compose service below):
#     DATABASE_URL=postgresql+psycopg2://scm:scm@localhost:5432/scm
DATABASE_URL=sqlite:///data/processed/app.db

# -----------------------------------------------------------------------------
# Postgres (consumed by docker-compose.yml)
# -----------------------------------------------------------------------------
# These are read by `docker compose up` to initialise the postgres container.
# Defaults baked into docker-compose.yml are scm/scm/scm on port 5432, so a
# fresh clone works without setting any of these. Override here for real dev.
POSTGRES_USER=scm
POSTGRES_PASSWORD=scm
POSTGRES_DB=scm
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Runtime environment label. One of: development | test | production
APP_ENV=development

# Logging verbosity. One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
